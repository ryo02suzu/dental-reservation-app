# ─── 必須 ──────────────────────────────────────────────────────────────────

# PostgreSQL 接続文字列。
# Supabase の場合: ダッシュボード → Project Settings → Database → Connection string。
#   - 通常は「Connection pooling」(Transaction mode, port 6543) を推奨。
#   - パスワードを含むので秘匿すること（リポジトリにコミットしない）。
# 例（Supabase Pooler）:
#   DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
# 例（Supabase 直結）:
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# セッション署名鍵（16文字以上）。本番では必須（未設定だと起動失敗）。
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── 任意 ──────────────────────────────────────────────────────────────────

# 実行モード（development / production）
NODE_ENV=development

# 待ち受けポート
PORT=5000

# SSL の明示制御（通常は未設定でOK。ローカル以外は自動でSSL有効）
#   require → 常にSSL有効 / disable → 常にSSL無効
# PGSSL=require

# メール送信（Resend）。未設定時はメール送信をスキップしてログ出力のみ。
RESEND_API_KEY=

# SMS送信（Twilio）。3つ揃わない場合はSMS無効。
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# LINE ログイン（フロント、LIFF）
VITE_LINE_LIFF_ID=
